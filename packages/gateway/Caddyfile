:80 {
    # Ensure /admin always has a trailing slash for proper path stripping
    redir /admin /admin/

    # API requests
    handle /api* {
        uri strip_prefix /api
        reverse_proxy api:{$API_PORT}
    }

    # Admin UI
    handle_path /admin* {
        reverse_proxy web-admin:{$WEB_ADMIN_PORT}
    }

    # Public UI (Fallback)
    handle {
        reverse_proxy web-public:{$WEB_PUBLIC_PORT}
    }
}
