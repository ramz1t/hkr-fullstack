:80 {
    # Ensure /admin always has a trailing slash for proper path stripping
    redir /admin /admin/

    # API requests
    handle /api* {
        uri strip_prefix /api
        reverse_proxy api:4000
    }

    # Admin UI
    handle_path /admin* {
        reverse_proxy web-admin:3001
    }

    # Public UI (Fallback)
    handle {
        reverse_proxy web-public:3000
    }
}
