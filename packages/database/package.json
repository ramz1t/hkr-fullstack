{
  "name": "@repo/database",
  "version": "1.0.0",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "scripts": {
    "dev": "tsc --watch --preserveWatchOutput",
    "build": "tsc",
    "lint": "eslint --fix",
    "prisma:generate": "bun prisma generate",
    "prisma:push": "bun prisma db push --accept-data-loss",
    "prisma:format": "bun prisma format",
    "prisma:seed": "bun run prisma/seed.ts",
    "prisma:migrate": "bun prisma migrate deploy",
    "prisma:reset": "bun prisma migrate reset --force"
  },
  "prisma": {
    "seed": "bun --env-file=../../.env run prisma/seed.ts"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0"
  }
}
