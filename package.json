{
  "name": "hkr-fullstack",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prisma:generate": "bun --filter @repo/database prisma:generate",
    "prisma:seed": "bun --filter @repo/database prisma:seed",
    "prisma:reset": "bun --filter @repo/database prisma:reset",
    "prisma:push": "bun --filter @repo/database prisma:push",
    "clean": "rm -rf node_modules **/node_modules **/dist **/.next **/.turbo **/.cache **/build **/tsconfig.tsbuildinfo .eslintcache"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.7",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
